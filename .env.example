# ─── Supabase ────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Get these from: Supabase Dashboard → Project Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ─── Optional: Anthropic (for AI plant search) ────────────────────────────────
# If you want the AI auto-fill feature to work in local dev, add your key here.
# In production on Vercel, set this as an environment variable in the dashboard.
# WARNING: Do NOT commit .env.local to GitHub. It is already in .gitignore.
VITE_ANTHROPIC_API_KEY=your-anthropic-key-here
